{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "readme": "docs/STUDY_GUIDE.md",
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/node_modules/**"
  ],
  "name": "CB8 API Documentation",
  "includeVersion": true,
  "validation": {
    "notExported": false
  }
}
